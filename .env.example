# Hermes Workspace + Hermes Agent Docker Compose example
#
# Copy to .env, then fill in at least one provider key plus the required
# secrets below:
#   cp .env.example .env

# ── LLM provider: pick the one(s) you actually use ──────────────────────────
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...
# GEMINI_API_KEY=AIza...   # alias Hermes also recognizes
# GROQ_API_KEY=gsk_...
# MISTRAL_API_KEY=...
# MINIMAX_API_KEY=...
# OPENCODE_GO_API_KEY=...

# Optional tool/service keys
# TAVILY_API_KEY=tvly-...

# ── Required secrets ─────────────────────────────────────────────────────────
# Used by hermes-workspace to authenticate to the Hermes gateway.
# Generate with: openssl rand -hex 32
API_SERVER_KEY=replace-with-a-long-random-secret

# Password for the Hermes Workspace web UI.
# Generate with: openssl rand -hex 32
HERMES_PASSWORD=replace-with-a-different-long-random-secret

# ── Persistent Hermes data ──────────────────────────────────────────────────
# Host path mounted into the hermes-agent container at /opt/data.
HERMES_DATA_PATH=/mnt/vol/hermes

# ── Proxy / HTTPS settings ───────────────────────────────────────────────────
# Set COOKIE_SECURE=1 when the workspace is served over HTTPS
# (Dokploy domain, Tailscale Serve HTTPS, Traefik, Caddy, etc.).
COOKIE_SECURE=0

# Set TRUST_PROXY=1 only when running behind a trusted reverse proxy that
# sanitizes forwarded headers.
TRUST_PROXY=0

# ── Optional gateway overrides ───────────────────────────────────────────────
# The gateway must listen on the Docker network so hermes-workspace can reach it.
# 0.0.0.0 is correct here because port 8642 is not published to the host.
API_SERVER_HOST=0.0.0.0
